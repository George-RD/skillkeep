{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "skillkeep",
  "version": "0.1.0",
  "identifier": "dev.skillkeep.app",
  "build": {
    "beforeDevCommand": "bun run --cwd ../packages/ui dev",
    "beforeBuildCommand": "bun run --cwd ../packages/ui build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../packages/ui/dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/skillkeep"]
  }
}
